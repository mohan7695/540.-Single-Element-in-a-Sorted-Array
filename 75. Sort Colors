class Solution {
    public void sortColors(int[] nums) {
        int first=0;
        int mid=0;
        int last=nums.length-1;
 
        while(mid<=last){
           
            if(nums[mid]==0){
              int temp=nums[first];
               nums[first]=nums[mid];
               nums[mid]=temp;
        
        first++;
        mid++;
            }
            else if(nums[mid]==1){
                mid++;
            }
            else{
              int temp=nums[last];
               nums[last]=nums[mid];
               nums[mid]=temp;
                last--;
            }
        }

    }
}
