class Solution {
    public boolean canPartitionGrid(int[][] grid) {
        int n=grid.length;
        int m=grid[0].length;

    long sum=0;
    for(int i=0;i<n;i++){
        for(int j=0;j<m;j++){
            sum+=grid[i][j];
        }
    }

    long target=0;
    for(int i=0;i<n;i++){
        for(int j=0;j<m;j++){
            target+=grid[i][j];
        

    }

    if(target==sum-target){
        return true;
    }
    }
    long col=0;
      for(int i=0;i<m;i++){
        for(int j=0;j<n;j++){
            col+=grid[j][i];
        }

        if(col==sum-col){
            return true;
        }
      }
    return false;

    }
}
