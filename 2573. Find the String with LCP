class Solution {
    public String findTheString(int[][] lcp) {
     int n=lcp.length;
     char[] s=new char[n];
     int next=0;

     for(int i=0;i<n;i++){
        if(s[i]==0){
            if(next>=26)
                return "";
            s[i]=(char) ('a' + next++);
        }
        for(int j=i+1;j<n;j++){
            if(lcp[i][j]>0){
                if(s[j]==0){
                    s[j]=s[i];
                }
                else if(s[j]!=s[i]){
                    return "";
                }
            }
            else{
                if(s[j]==s[i]){
                    return "";
                }
            }
        }
     }
     int[][] comp=new int[n][n];
     for(int i=n-1;i>=0;i--){
        for(int j=n-1;j>=0;j--){
            if(s[i]==s[j]){
                comp[i][j]=(i+1< n && j+1<n)? comp[i+1][j+1]+1:1;
            }
            else{
                comp[i][j]=0;
            }
            if(comp[i][j]!=lcp[i][j]) return "";
        }
     }   
    
    return new String(s);
}
}
