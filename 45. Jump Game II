class Solution {
    public int jump(int[] nums) {
        int n=nums.length-1;
        int total=0 ,coverage=0,last=0;
if(nums.length==1) return 0;

        for(int i=0;i<nums.length;i++){

            coverage=Math.max(coverage,i+nums[i]);

            if(i==last) {
                last=coverage;
                total++;
            
            
            if(coverage>=n){
                return total;
            }
        }
        }
        
        
        return total;
    }
}
